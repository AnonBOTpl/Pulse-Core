{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PulseCore",
  "version": "0.9.3",
  "identifier": "com.pulsecore.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PulseCore",
        "width": 1200,
        "height": 900,
        "additionalBrowserArgs": "--enable-accelerated-2d-canvas --enable-webgl --ignore-gpu-blocklist --disable-gpu-vsync --force-gpu-rasterization --enable-gpu-rasterization --enable-features=WebAssemblySIMD,SharedArrayBuffer --disable-software-rasterizer --autoplay-policy=no-user-gesture-required --webview-process-program-name=PulseCore --title-is-program-name"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "nsis/installer.bmp",
        "headerImage": "nsis/header.bmp"
      }
    }
  }
}