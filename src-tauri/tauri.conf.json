{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pulsecore",
  "version": "0.1.0",
  "identifier": "com.admin.pulsecore",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pulsecore",
        "width": 1200,
        "height": 900,
        "additionalBrowserArgs": "--enable-accelerated-2d-canvas --enable-webgl --ignore-gpu-blocklist --disable-gpu-vsync --force-gpu-rasterization --enable-gpu-rasterization --enable-features=WebAssemblySIMD,SharedArrayBuffer --disable-software-rasterizer --autoplay-policy=no-user-gesture-required"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
